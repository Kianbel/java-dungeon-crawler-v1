<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.canvas.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox fx:id="rootContainer" minWidth="800.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.GameController">

    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <StackPane fx:id="canvasContainer" HBox.hgrow="ALWAYS">
        <Canvas fx:id="canvas" />
    </StackPane>

    <VBox maxWidth="360.0" minWidth="360.0" prefWidth="360.0" spacing="15.0" HBox.hgrow="NEVER">

        <VBox fx:id="statsPanel" VBox.vgrow="NEVER">
            <padding>
                <Insets bottom="12" left="15" right="15" top="12" />
            </padding>
            <Label fx:id="statsHeader" text="CHARACTER STATUS" />
            <Region prefHeight="10" />

            <VBox spacing="6.0">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblHealth" text="Health:" />
                    <Label fx:id="healthValText" text="100/100" />
                </HBox>
                <Label fx:id="healthBar" style="-fx-font-size: 14px;" text="[■■■■■■■■■■■■■■■]" />

                <Region prefHeight="4" />

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblHunger" text="Hunger:" />
                    <Label fx:id="hungerValText" text="96/100" />
                </HBox>
                <Label fx:id="hungerBar" style="-fx-font-size: 14px;" text="[■■■■■■■■■■■■■■·]" />

                <Region prefHeight="6" />

                <HBox spacing="4">
                    <Label fx:id="lblArmor" text="Armor:" />
                    <Label fx:id="armorText" text="Tunic" />
                </HBox>

                <HBox spacing="4">
                    <Label fx:id="lblWeapon" text="Weapon:" />
                    <Label fx:id="weaponText" text="Sword" />
                </HBox>

                <Region prefHeight="4" />

                <HBox spacing="4">
                    <Label fx:id="lblCoins" text="Coins:" />
                    <Label fx:id="coinsText" text="0" />
                </HBox>
            </VBox>
        </VBox>

        <VBox fx:id="inventoryPanel" VBox.vgrow="ALWAYS" prefHeight="0">
            <padding>
                <Insets bottom="12" left="15" right="15" top="12" />
            </padding>
            <Label fx:id="inventoryHeader" text="INVENTORY" />
            <Region prefHeight="10" />

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-pane-border: transparent;">
                <content>
                    <VBox fx:id="inventoryBox" spacing="6.0" style="-fx-background-color: transparent;" />
                </content>
            </ScrollPane>
        </VBox>

        <VBox fx:id="logsPanel" VBox.vgrow="ALWAYS" prefHeight="0">
            <padding>
                <Insets bottom="12" left="15" right="15" top="12" />
            </padding>
            <Label fx:id="logsHeader" text="MESSAGE LOGS" />
            <Region prefHeight="10" />

            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-pane-border: transparent;">
                <content>
                    <VBox fx:id="logContainer" spacing="6.0" style="-fx-background-color: transparent;" />
                </content>
            </ScrollPane>
        </VBox>

        <VBox fx:id="controlsPanel" VBox.vgrow="NEVER">
            <padding>
                <Insets bottom="12" left="15" right="15" top="12" />
            </padding>
            <Label fx:id="controlsHeader" text="CONTROLS" />
            <Region prefHeight="8" />
            <VBox fx:id="controlsBox" spacing="4.0" VBox.vgrow="NEVER" />
        </VBox>
    </VBox>
</HBox>